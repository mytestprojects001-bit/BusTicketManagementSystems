## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.

# Visual Studio cache/options directory
.vs/
.vscode/
*.VC.db
*.VC.VC.opendb

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Build directory
bin/
obj/
[Oo]ut/

# Test Results
TestResults/
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
ProjectLockfile.json
project.lock.json
project.assets.json

# Visual Studio cache directory
.vs/

# Compiled source code
*.dll
*.exe
*.pdb

# NuGet Packages
*.nupkg
*.snupkg
.nuget/

# npm
node_modules/
package-lock.json
dist/

# Angular
.angular/
dist/
DomDistribution/

# Environment files
appsettings.Development.json
appsettings.Production.json
.env
.env.local
.env.*.local

# IDE
.idea/
.DS_Store
Thumbs.db

# Logs
logs/
*.log
log*.txt

# Entity Framework
Migrations/

# Dependencies
packages/
.packages/

# Build Artifacts
artifacts/
publish/

# Rider
.idea/
*.sln.iml

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Temp files
*.tmp
*.temp
*~

# VS Code
.vscode/settings.json
.vscode/extensions.json
*.code-workspace
